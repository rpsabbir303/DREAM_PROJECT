# Template only — copy to `.env` in the project root (gitignored) for local keys.
# npm run dev injects VITE_DEV_SERVER_URL=http://localhost:5173 for the Electron process (see package.json).
# Electron main loads `.env` via dotenv (see electron/main/env.ts).
#
# Jarvis MVP uses Google Gemini only (https://aistudio.google.com/apikey).
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FETCH_TIMEOUT_MS=120000
#
# Optional: network / execution guardrails (milliseconds)
JARVIS_ACTION_TIMEOUT_MS=45000
JARVIS_STREAM_CHUNK_READ_MS=120000
