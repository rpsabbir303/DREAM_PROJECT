# Template only — copy to `.env` in the project root (gitignored) for local keys.
# npm run dev injects VITE_DEV_SERVER_URL=http://localhost:5173 for the Electron process (see package.json).
# Electron main loads `.env` via dotenv (see electron/main/env.ts).
# Use a real secret from https://platform.openai.com/api-keys (must start with sk-). Template values are ignored.
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
# Optional: when set (non-placeholder), chat routes to Gemini first (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_FETCH_TIMEOUT_MS=120000
OPENAI_WHISPER_MODEL=whisper-1
# Optional: network / execution guardrails (milliseconds)
OPENAI_FETCH_TIMEOUT_MS=120000
OLLAMA_FETCH_TIMEOUT_MS=90000
JARVIS_ACTION_TIMEOUT_MS=45000
# Max idle time per stream read chunk (SSE / Ollama NDJSON); prevents hung "reasoning"
JARVIS_STREAM_CHUNK_READ_MS=120000
