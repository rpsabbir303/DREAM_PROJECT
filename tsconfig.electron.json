{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@shared/*": ["./shared/*"],
      "@electron/*": ["./electron/*"]
    },
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node", "electron"]
  },
  "include": ["electron/**/*.ts", "shared/**/*.ts"]
}
